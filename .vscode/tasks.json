{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Django: migrate",
      "type": "shell",
      "command": "${workspaceFolder}/.venv/bin/python",
      "args": [
        "manage.py",
        "migrate"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "Django: test",
      "type": "shell",
      "command": "${workspaceFolder}/.venv/bin/python",
      "args": [
        "manage.py",
        "test"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    }
  ]
}
